# Supabase — copy from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side only, NEVER expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Secret shared with Make.com to authenticate inbound webhook calls
MAKE_WEBHOOK_SECRET=your-random-secret-here

# Secret to protect the /api/assign-freelancer endpoint
ASSIGN_FREELANCER_SECRET=your-random-secret-here
